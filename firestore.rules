rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — only the owner can write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0;
      allow update: if request.auth != null
        && (
          resource.data.authorId == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'upvotedBy'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
        );
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 1000;
        allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;
        allow update: if false;
      }
    }
  }
}
